# Database (matches docker-compose.yml — no change needed if you use Docker)
DATABASE_URL=postgresql://els:els_dev@localhost:5432/els_builder

# Redis (matches docker-compose.yml — no change needed if you use Docker)
REDIS_URL=redis://localhost:6379

# Anthropic API key — required. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google AI (Gemini) API key — required. Get one at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Google Sheets service account — optional, only needed if exporting to Sheets
GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=

# Login password for the app — pick any value
APP_PASSWORD=

# Where uploaded files are stored on disk (relative to project root)
STORAGE_PATH=./storage
